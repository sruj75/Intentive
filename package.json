{
  "name": "intentive",
  "version": "0.0.0",
  "private": true,
  "description": "Intentive monorepo — Mobile, Desktop, Control Plane, Agent Runtime.",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "harness": "node tools/harness/run-harness.mjs",
    "harness:ci": "node tools/harness/run-harness.mjs",
    "harness:test": "node tools/harness/test.mjs",
    "sensor:impact-radius": "node tools/sensors/impact-radius/index.mjs",
    "sensor:impact-radius:test": "node tools/sensors/impact-radius/test.mjs",
    "sensor:contract-drift": "node tools/sensors/contract-drift/index.mjs",
    "sensor:contract-drift:test": "node tools/sensors/contract-drift/test.mjs",
    "sensor:harness-health": "node tools/sensors/harness-health/index.mjs",
    "sensor:harness-health:test": "node tools/sensors/harness-health/test.mjs",
    "sensor:factory-report": "node tools/sensors/factory-report/index.mjs",
    "sensor:factory-report:test": "node tools/sensors/factory-report/test.mjs",
    "factory:ledger": "node tools/factory/ledger-cli.mjs",
    "factory:recommend": "node tools/factory/recommend-cli.mjs",
    "factory:test": "node tools/factory/finding-ids.test.mjs && node tools/factory/test.mjs",
    "docs:check": "node tools/docs/check-markdown-links.mjs && node tools/docs/check-context-vocabulary.mjs && node tools/docs/check-agent-docs.mjs && node tools/docs/check-factory-docs.mjs",
    "docs:context:test": "node tools/docs/check-context-vocabulary.test.mjs",
    "docs:agents:test": "node tools/docs/check-agent-docs.test.mjs",
    "docs:factory:test": "node tools/docs/check-factory-docs.test.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,yml,yaml}\"",
    "lint": "pnpm docs:check && eslint .",
    "lint:fix": "eslint . --fix",
    "lint:architecture:test": "node tools/linters/eslint-plugin-intentive-architecture/test.js && node tools/linters/rust-architecture/test.js",
    "lint:architecture:rust": "node tools/linters/rust-architecture/check.js --strict",
    "test": "turbo run test",
    "coverage": "pnpm --dir apps/desktop test:coverage",
    "prepare": "husky",
    "dev": "turbo run dev",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@intentive/eslint-plugin-architecture": "workspace:*",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "turbo": "^2.0.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.5.2"
  },
  "lint-staged": {
    "*.{json,md,yml,yaml}": "prettier --write",
    "*.{ts,tsx,js,mjs,cjs}": "prettier --write",
    "{apps,services}/*/src/**/*.{ts,tsx,js,mjs,cjs}": "eslint --fix"
  }
}
