{
  "name": "intentive",
  "version": "0.0.0",
  "private": true,
  "description": "Intentive monorepo — Mobile, Desktop, Control Plane, Agent Runtime.",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:architecture:test": "node tools/linters/eslint-plugin-intentive-architecture/test.js",
    "test": "turbo run test",
    "dev": "turbo run dev",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@intentive/eslint-plugin-architecture": "workspace:*",
    "eslint": "^9.0.0",
    "turbo": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
