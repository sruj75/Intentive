# Copy to `.env` for local boot, then run with Node's --env-file (see
# docs/DEVELOPMENT.md). Validated at startup by `src/config/env.ts` (`loadConfig`).
# Domains must not re-parse `process.env`. `.env` is git-ignored; this example is
# the committed template — never put a real key or password here.
#
# In production these values come from Google Secret Manager (fetched at boot by
# scripts/boot-fetch-secrets.mjs); the values shown here are the LOCAL ones.

# Public WebSocket URL clients receive from the Control Plane's GET /agent and then
# dial. Locally this must be the loopback URL the Runtime's WS server listens on.
# The Runtime moves OFF 8080 locally so it does not collide with the Control Plane.
PUBLIC_WS_URL=ws://localhost:8787/ws

# Ports. PORT is the public WS server; INTERNAL_PORT is the private HTTP surface
# (/health + /internal/sessions/start). Defaults are 8080/8081 — locally PORT is
# moved to 8787 so the Control Plane keeps 8080.
PORT=8787
INTERNAL_PORT=8081

# Private Internal API shared secrets. Locally these are dummy strings; the only
# rule is they must MATCH the Control Plane's paired vars (see
# services/control-plane/.env):
#   INTERNAL_SECRET_FROM_CONTROL_PLANE  ==  Control Plane INTERNAL_SECRET_TO_RUNTIME
#   INTERNAL_SECRET_TO_CONTROL_PLANE    ==  Control Plane INTERNAL_SECRET_FROM_RUNTIME
INTERNAL_SECRET_FROM_CONTROL_PLANE=local-cp-to-ar
CONTROL_PLANE_INTERNAL_BASE_URL=http://localhost:8080
INTERNAL_SECRET_TO_CONTROL_PLANE=local-ar-to-cp

# Neon Postgres for the runtime-owned `agent_runtime` schema. Local dev points at
# an isolated Neon dev branch, NEVER production. Use the DIRECT (non-`-pooler`)
# host — LangGraph's persistent connections / prepared statements conflict with
# Neon's PgBouncer pooling. Fetch it for branch `dev-local-smoke`.
NEON_DATABASE_URL=postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require
NEON_DATABASE_ROLE=neondb_owner

# Neon Auth JWT verification (client WebSocket connect). Same live Neon Auth
# instance prod uses (not branched); these real values are safe to commit.
NEON_AUTH_JWKS_URL=https://ep-lucky-dew-aqkjv8j5.neonauth.c-8.us-east-1.aws.neon.tech/neondb/auth/.well-known/jwks.json
NEON_AUTH_ISSUER=https://ep-lucky-dew-aqkjv8j5.neonauth.c-8.us-east-1.aws.neon.tech
NEON_AUTH_AUDIENCE=https://ep-lucky-dew-aqkjv8j5.neonauth.c-8.us-east-1.aws.neon.tech

# OpenRouter model provider (Interactive Turn / DeepAgents). REQUIRED — this is the
# one secret you must supply yourself for a companion reply. The default model is a
# free OpenRouter model; override if you like.
OPENROUTER_API_KEY=sk-or-REPLACE_WITH_YOUR_KEY
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# RUNTIME_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# Optional Langfuse prompt management + tracing (both keys required to enable).
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_MODE=callback

# Optional Sentry error/crash capture. Leave blank locally.
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=staging
# SENTRY_RELEASE=agent-runtime@local
# SENTRY_MODE=errors-only

# Repo-tier integration tests only — not read by `loadConfig`:
# NEON_API_KEY=
# NEON_PROJECT_ID=
