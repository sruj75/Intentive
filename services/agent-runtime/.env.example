# Copy to `.env` for local boot. Validated at startup by `src/config/env.ts`
# (`loadConfig`). Domains must not re-parse `process.env`.

# Public WebSocket URL clients receive after Session Start (Control Plane Routing).
PUBLIC_WS_URL=wss://runtime.heyintentive.com/ws

# Private Internal API shared secret (Control Plane → Runtime).
INTERNAL_SECRET_FROM_CONTROL_PLANE=replace-me

# Private Control Plane notification handoff (Runtime → Control Plane).
CONTROL_PLANE_INTERNAL_BASE_URL=https://control-plane.internal
INTERNAL_SECRET_TO_CONTROL_PLANE=replace-me

# Neon Postgres connection for the Runtime-owned `agent_runtime` schema.
NEON_DATABASE_URL=postgresql://agent_runtime_app:password@host/neondb?sslmode=require
NEON_DATABASE_ROLE=agent_runtime_app

# Neon Auth JWT verification (client WebSocket connect).
NEON_AUTH_JWKS_URL=https://auth.example.com/.well-known/jwks.json
NEON_AUTH_ISSUER=https://auth.example.com
NEON_AUTH_AUDIENCE=intentive-runtime

# OpenRouter model provider (Interactive Turn / DeepAgents).
OPENROUTER_API_KEY=sk-or-replace-me
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# RUNTIME_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# Optional Langfuse prompt management + tracing (both keys required to enable).
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_MODE=callback

# Optional Sentry error/crash capture. The real DSN lives in Sentry project
# `heyintentive/agent-runtime`; do not commit it here.
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=staging
# SENTRY_RELEASE=agent-runtime@local
# SENTRY_MODE=errors-only

# Boot defaults (override only when needed):
# PORT=8080
# INTERNAL_PORT=8081

# Repo-tier integration tests only — not read by `loadConfig`:
# NEON_API_KEY=
# NEON_PROJECT_ID=
