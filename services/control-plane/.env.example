# Copy to `.env` for local boot, then run with Node's --env-file (see
# docs/DEVELOPMENT.md). Validated at startup by `src/config/env.ts` (`loadConfig`).
# Domains must not re-parse `process.env`. `.env` is git-ignored; this example is
# the committed template — never put a real password or token here.

# HTTP port the Control Plane listens on (clients + internal surface).
PORT=8080

# Neon Postgres — the control_plane-owned schema. Local dev points at an isolated
# Neon dev branch, NEVER production. Pooled connection string is fine here. Fetch
# it from the Neon console / MCP for branch `dev-local-smoke`.
NEON_DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require
NEON_DATABASE_ROLE=neondb_owner

# Neon Auth — shared JWKS verifier config (the same live Neon Auth instance prod
# uses; not branched). These exact values are the project's real ones and are safe
# to commit (the JWKS is public). https://neon.com/docs/guides/neon-authorize
NEON_AUTH_JWKS_URL=https://ep-lucky-dew-aqkjv8j5.neonauth.c-8.us-east-1.aws.neon.tech/neondb/auth/.well-known/jwks.json
NEON_AUTH_ISSUER=https://ep-lucky-dew-aqkjv8j5.neonauth.c-8.us-east-1.aws.neon.tech
NEON_AUTH_AUDIENCE=https://ep-lucky-dew-aqkjv8j5.neonauth.c-8.us-east-1.aws.neon.tech

# Internal HTTP surface — Directional Secrets (one per direction). Locally these
# are dummy strings; the only rule is they must MATCH the Agent Runtime's paired
# vars (see services/agent-runtime/.env): the value below must equal the Runtime's
# INTERNAL_SECRET_FROM_CONTROL_PLANE / INTERNAL_SECRET_TO_CONTROL_PLANE.
RUNTIME_INTERNAL_BASE_URL=http://localhost:8081
INTERNAL_SECRET_TO_RUNTIME=local-cp-to-ar          # == Runtime INTERNAL_SECRET_FROM_CONTROL_PLANE
INTERNAL_SECRET_FROM_RUNTIME=local-ar-to-cp        # == Runtime INTERNAL_SECRET_TO_CONTROL_PLANE
INTERNAL_SECRET_FOR_MAINTENANCE=local-maintenance

# Expo Push Service — optional. Leave blank locally; the WebSocket companion reply
# is the journey's core, and push delivery to a real device needs a real token.
# EXPO_ACCESS_TOKEN=

# Optional Sentry error capture. Leave blank locally to keep telemetry disabled.
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
# SENTRY_RELEASE=control-plane@local
# SENTRY_MODE=errors-only
