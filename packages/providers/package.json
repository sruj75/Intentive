{
  "name": "@intentive/providers",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared cross-cutting clients: auth (Neon Auth JWKS), telemetry, feature flags. The single explicit interface for cross-cutting concerns.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./auth": {
      "types": "./src/auth.ts",
      "default": "./src/auth.ts"
    },
    "./telemetry": {
      "types": "./src/telemetry.ts",
      "default": "./src/telemetry.ts"
    },
    "./flags": {
      "types": "./src/flags.ts",
      "default": "./src/flags.ts"
    }
  },
  "scripts": {
    "build": "tsc --outDir dist",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run build && node --test"
  },
  "dependencies": {
    "jose": "^6.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0"
  }
}
