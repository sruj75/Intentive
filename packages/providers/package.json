{
  "name": "@intentive/providers",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared cross-cutting clients: auth (Neon Auth JWKS), telemetry, feature flags. The single explicit interface for cross-cutting concerns.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "source": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./auth": {
      "types": "./src/auth.ts",
      "source": "./src/auth.ts",
      "default": "./dist/auth.js"
    },
    "./telemetry": {
      "types": "./src/telemetry.ts",
      "source": "./src/telemetry.ts",
      "default": "./dist/telemetry.js"
    },
    "./observability": {
      "types": "./src/observability/index.ts",
      "source": "./src/observability/index.ts",
      "default": "./dist/observability/index.js"
    },
    "./flags": {
      "types": "./src/flags.ts",
      "source": "./src/flags.ts",
      "default": "./dist/flags.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc --outDir dist",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run build && node --test"
  },
  "dependencies": {
    "@langchain/core": "^1.1.49",
    "@sentry/node": "^10.58.0",
    "jose": "^6.1.2",
    "langfuse-langchain": "^3.38.20"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0"
  }
}
