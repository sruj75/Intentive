# Copy to `.env` for local Desktop Client development. Values prefixed with
# `VITE_` are compiled into the webview by Vite; Rust values are read by
# `src-tauri` at compile time for release builds and runtime for local cargo runs.

# Neon Auth webview sign-in.
# VITE_NEON_AUTH_URL=https://auth.example.neon.tech

# Control Plane Routing source for Rust `GET /agent`.
# INTENTIVE_CONTROL_PLANE_URL=https://control-plane.example.com

# Optional Sentry error/crash capture. The real DSN lives in Sentry project
# `heyintentive/desktop`; do not commit it here. The DSN is public, but
# source-map upload uses the private `SENTRY_AUTH_TOKEN` secret in GitHub Actions.
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=development
# VITE_SENTRY_RELEASE=desktop@local
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
# SENTRY_RELEASE=desktop@local
