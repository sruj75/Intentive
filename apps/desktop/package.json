{
  "name": "intentive",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run && (cd ../.. && cargo +stable test --manifest-path apps/desktop/src-tauri/Cargo.toml)",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "smoke": "pnpm --filter @intentive/desktop-smoke smoke",
    "eval:privacy": "cargo +stable test --manifest-path src-tauri/Cargo.toml privacy_eval -- --ignored --nocapture"
  },
  "dependencies": {
    "@neondatabase/neon-js": "^0.6.1-beta",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@intentive/protocol": "workspace:*",
    "@tauri-apps/cli": "^2",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^25.9.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/ui": "^4.1.8",
    "jsdom": "^25.0.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.8"
  }
}
