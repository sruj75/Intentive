# Copy to `.env`. Neon Auth base URL (public endpoint) — its Better Auth server's
# JWKS backs the shared verifier (#15). Consumed by
# src/domains/auth/service/neon-client.ts.
EXPO_PUBLIC_NEON_AUTH_BASE_URL=https://ep-lucky-dew-aqkjv8j5.neonauth.c-8.us-east-1.aws.neon.tech/neondb/auth

# Control Plane base URL (public HTTPS). The real LaunchStateSource calls
# `${base}/me` to hydrate Launch State (#23). Consumed by
# src/providers/launch-state/control-plane-source.ts. Leave blank in dev: with no
# Neon session the source returns signed-out and never calls the Control Plane.
EXPO_PUBLIC_CONTROL_PLANE_BASE_URL=
