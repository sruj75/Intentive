{
  "expo": {
    "name": "Intentive",
    "slug": "intentive-mobile",
    "scheme": "intentive",
    "version": "0.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.heyintentive.expo"
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-web-browser"],
    "experiments": {
      "typedRoutes": false
    }
  }
}
